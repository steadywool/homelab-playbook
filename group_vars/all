nas:
  users:
    - username: test
      password: test
      groups: users
  home_directory: /mnt/home
  samba_shares:
    - path: /mnt/share
      name: share
      allowed_users:
        - test
  nfs_shares:
    - path: /mnt/share
      options: rw,all_squash,anonuid=0,anongid=100,subtree_check
      allowed_ips:
        - 192.168.1.10/24